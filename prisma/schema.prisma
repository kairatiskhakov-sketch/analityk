generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
}

// --- NextAuth.js + Saldo CRM пользователи ---
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          Role      @default(MANAGER)
  initials      String?
  telegramId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  telegramChats TelegramChat[]
  dashboardModules DashboardModule[]
}

/// Включённые блоки дашборда на пользователя
model DashboardModule {
  id         String   @id @default(cuid())
  userId     String
  moduleKey  String
  isEnabled  Boolean  @default(true)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- CRM & integrations ---
model CrmConnection {
  id         String    @id @default(cuid())
  crmType    String // "bitrix24" | "amocrm"
  isActive   Boolean   @default(false)
  lastSyncAt DateTime?

  bitrixDomain          String?
  bitrixWebhookToken    String?
  /// ID пользователя из сегмента URL вебхука (/rest/{id}/)
  bitrixUserId          String?
  /// ID пользователя из ответа profile (для отображения)
  bitrixProfileUserId   String?

  amoSubdomain       String?
  amoClientId        String?
  amoClientSecret    String?
  amoAccessToken     String?
  amoRefreshToken    String?
  amoTokenExpiresAt  DateTime?

  pipelineStages PipelineStage[]
  dealPipelines  DealPipeline[]
}

/// Кеш справочников Bitrix (SOURCE, причины отказа и т.д.) для расшифровки ID
model CrmDictionary {
  id         String   @id @default(cuid())
  crmType    String
  entityId   String
  externalId String
  name       String
  extra      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([crmType, entityId, externalId])
  @@index([crmType, entityId])
}

/// Воронки сделок Bitrix24 (кеш справочника)
model DealPipeline {
  id           String        @id @default(cuid())
  connectionId String
  connection   CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  externalId   String
  name         String
  sort         Int           @default(0)
  crmType      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([connectionId, externalId, crmType])
}

/// Стадии воронки (кеш справочника)
model PipelineStage {
  id                 String        @id @default(cuid())
  connectionId       String
  connection         CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  entityType         String // "lead" | "deal"
  externalId         String
  name               String
  sort               Int
  isSuccess          Boolean       @default(false)
  isLost             Boolean       @default(false)
  color              String?
  categoryExternalId String?
  crmType            String

  @@unique([connectionId, entityType, externalId, crmType])
}

model GoogleConnection {
  id             String   @id @default(cuid())
  email          String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime

  adsEnabled          Boolean @default(false)
  adsCustomerId       String?
  adsDeveloperToken   String?

  sheetsEnabled       Boolean @default(false)
  sheetsSpreadsheetId String?

  analyticsEnabled    Boolean @default(false)
  analyticsPropertyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramConnection {
  id       String  @id @default(cuid())
  botToken String
  isActive Boolean @default(false)

  notifyNewLead     Boolean @default(true)
  notifyDealWon     Boolean @default(true)
  notifyDealLost    Boolean @default(false)
  notifyDailyReport Boolean @default(true)
  notifyPlanAlert   Boolean @default(true)
  dailyReportTime   String  @default("18:00")

  chats TelegramChat[]
}

model TelegramChat {
  id           String @id @default(cuid())
  chatId       String
  chatType     String // "private" | "group" | "supergroup"
  title        String?
  connectionId String
  connection   TelegramConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?              @relation(fields: [userId], references: [id])
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())

  @@unique([chatId, connectionId])
}

/// Кеш пользователей CRM (Bitrix user id → имя)
model Manager {
  id         String @id @default(cuid())
  externalId String
  crmType    String
  name       String
  email      String?
  telegramId String?
  isActive   Boolean @default(true)

  planTargets PlanTarget[]

  @@unique([externalId, crmType])
}

/// План продаж по периодам (команда и менеджеры)
model PlanTarget {
  id         String   @id @default(cuid())
  period     String // "2026-04" | "2026-Q2" | "2026"
  periodType String // "month" | "quarter" | "year"
  managerId  String? // null = общий план на команду
  target     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  manager    Manager? @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([period, periodType, managerId])
}

model SalesPlan {
  id        String   @id @default(cuid())
  period    String
  managerId String?
  target    Float
  createdAt DateTime @default(now())
}

/// Пользовательская классификация стадий сделок Bitrix24 для аналитики
model StageConfig {
  id           String   @id @default(cuid())
  externalId   String
  name         String
  pipelineId   String
  pipelineName String
  crmType      String   @default("bitrix24")
  type         String
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([externalId, crmType])
}
