DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_sales_analytics?schema=public"
# Neon / Supabase: вставь connection string из консоли (SSL обычно ?sslmode=require)

# Auth.js v5: можно AUTH_SECRET / AUTH_URL или классические:
AUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# 32 байта: либо 32 символа UTF-8, либо 64 hex-символа; иначе ключ берётся как SHA-256 от строки
ENCRYPTION_KEY=

AMOCRM_CLIENT_ID=
AMOCRM_CLIENT_SECRET=
AMOCRM_REDIRECT_URI=http://localhost:3000/api/crm/amo/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# опционально: MCC / менеджерский аккаунт для заголовка login-customer-id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta (Facebook) Ads
# Создать app: https://developers.facebook.com/apps → Business
# Settings → Basic → App ID + App Secret
# Facebook Login → Settings → Valid OAuth Redirect URIs:
#   http://localhost:3000/api/integrations/meta/callback (dev)
#   https://<prod-domain>/api/integrations/meta/callback (prod)
# Permissions: ads_read + business_management (требуют App Review для прод)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback

# TikTok Ads
# Создать app: https://business-api.tiktok.com/portal → My Apps → Create
# App ID + Secret
# Redirect URL:
#   http://localhost:3000/api/integrations/tiktok/callback (dev)
#   https://<prod-domain>/api/integrations/tiktok/callback (prod)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/integrations/tiktok/callback

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Cron: POST /api/cron, Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
