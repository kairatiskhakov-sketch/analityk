generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
}

enum OrgRole {
  OWNER
  ADMIN
  VIEWER
}

/// Тенант. Каждая подключённая компания = одна Organization.
/// Все CRM/рекламные интеграции, менеджеры, планы, настройки — внутри неё.
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free") // free | pro | business
  /// Публичный ключ для JS tracking-сниппета. Клиент вставляет на лендинг.
  trackingKey String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members             OrgMember[]
  invites             OrgInvite[]
  audits              OrgAudit[]
  crmConnections      CrmConnection[]
  googleConnections   GoogleConnection[]
  telegramConnections TelegramConnection[]
  managers            Manager[]
  planTargets         PlanTarget[]
  salesPlans          SalesPlan[]
  stageConfigs        StageConfig[]
  crmDictionaries     CrmDictionary[]

  @@index([slug])
  @@index([trackingKey])
}

/// Журнал действий над организацией (audit log).
/// Пишется best-effort из мутирующих эндпоинтов. Не должен валить операцию.
/// При удалении Organization — каскадно уничтожается (OrgAudit живёт в scope org).
model OrgAudit {
  id             String   @id @default(cuid())
  orgId          String
  /// null для системных действий (cron, scheduler, миграции)
  actorUserId    String?
  /// имя действия в dot.case: "invite.created", "member.role_changed", ...
  action         String
  targetUserId   String?
  targetEmail    String?
  targetInviteId String?
  /// произвольные поля (beforeRole, afterRole, reason, ...)
  details        Json?
  createdAt      DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([actorUserId])
  @@index([targetUserId])
}

/// Приглашение в организацию по токену. Отправляется пользователю,
/// которого ещё нет в системе (или просто «по ссылке»). Принимается
/// залогиненным пользователем через POST /api/invites/:token/accept.
model OrgInvite {
  id         String    @id @default(cuid())
  orgId      String
  email      String // email, для кого приглашение (lowercased)
  role       OrgRole   @default(VIEWER)
  token      String    @unique
  invitedBy  String? // userId того, кто создал приглашение
  acceptedBy String? // userId того, кто принял (null если pending)
  acceptedAt DateTime?
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([token])
}

/// Связка User ↔ Organization. Пользователь может быть в нескольких org.
model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole  @default(VIEWER)
  invitedBy String?
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

// --- NextAuth.js + Saldo CRM пользователи ---
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          Role      @default(MANAGER)
  initials      String?
  telegramId    String?
  /// Последняя выбранная организация (для переключателя в UI)
  currentOrgId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  telegramChats    TelegramChat[]
  dashboardModules DashboardModule[]
  orgMemberships   OrgMember[]
}

/// Включённые блоки дашборда на пользователя
model DashboardModule {
  id        String   @id @default(cuid())
  userId    String
  /// nullable для обратной совместимости; UI дашборда per-user остаётся,
  /// но можно будет фильтровать настройки per-org в будущем
  orgId     String?
  moduleKey String
  isEnabled Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleKey])
  @@index([userId])
  @@index([orgId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- CRM & integrations ---
model CrmConnection {
  id         String    @id @default(cuid())
  orgId      String
  crmType    String // "bitrix24" | "amocrm"
  /// Активное подключение per-org (в рамках одной org только одно isActive=true)
  isActive   Boolean   @default(false)
  lastSyncAt DateTime?

  bitrixDomain        String?
  bitrixWebhookToken  String?
  /// ID пользователя из сегмента URL вебхука (/rest/{id}/)
  bitrixUserId        String?
  /// ID пользователя из ответа profile (для отображения)
  bitrixProfileUserId String?

  amoSubdomain      String?
  amoClientId       String?
  amoClientSecret   String?
  amoAccessToken    String?
  amoRefreshToken   String?
  amoTokenExpiresAt DateTime?

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipelineStages PipelineStage[]
  dealPipelines  DealPipeline[]

  @@index([orgId])
  @@index([orgId, isActive])
}

/// Кеш справочников Bitrix (SOURCE, причины отказа и т.д.) для расшифровки ID
model CrmDictionary {
  id         String   @id @default(cuid())
  orgId      String
  crmType    String
  entityId   String
  externalId String
  name       String
  extra      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, crmType, entityId, externalId])
  @@index([orgId, crmType, entityId])
}

/// Воронки сделок Bitrix24 (кеш справочника)
model DealPipeline {
  id           String        @id @default(cuid())
  connectionId String
  connection   CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  externalId   String
  name         String
  sort         Int           @default(0)
  crmType      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([connectionId, externalId, crmType])
}

/// Стадии воронки (кеш справочника)
model PipelineStage {
  id                 String        @id @default(cuid())
  connectionId       String
  connection         CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  entityType         String // "lead" | "deal"
  externalId         String
  name               String
  sort               Int
  isSuccess          Boolean       @default(false)
  isLost             Boolean       @default(false)
  color              String?
  categoryExternalId String?
  crmType            String

  @@unique([connectionId, entityType, externalId, crmType])
}

model GoogleConnection {
  id             String   @id @default(cuid())
  orgId          String
  email          String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime

  adsEnabled        Boolean @default(false)
  adsCustomerId     String?
  adsDeveloperToken String?

  sheetsEnabled       Boolean @default(false)
  sheetsSpreadsheetId String?

  analyticsEnabled    Boolean @default(false)
  analyticsPropertyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model TelegramConnection {
  id       String  @id @default(cuid())
  orgId    String
  botToken String
  isActive Boolean @default(false)

  notifyNewLead     Boolean @default(true)
  notifyDealWon     Boolean @default(true)
  notifyDealLost    Boolean @default(false)
  notifyDailyReport Boolean @default(true)
  notifyPlanAlert   Boolean @default(true)
  dailyReportTime   String  @default("18:00")

  org   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chats TelegramChat[]

  @@index([orgId])
}

model TelegramChat {
  id           String             @id @default(cuid())
  chatId       String
  chatType     String // "private" | "group" | "supergroup"
  title        String?
  connectionId String
  connection   TelegramConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?              @relation(fields: [userId], references: [id])
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())

  @@unique([chatId, connectionId])
}

/// Кеш пользователей CRM (Bitrix user id → имя)
model Manager {
  id         String  @id @default(cuid())
  orgId      String
  externalId String
  crmType    String
  name       String
  email      String?
  telegramId String?
  isActive   Boolean @default(true)

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  planTargets PlanTarget[]

  @@unique([orgId, externalId, crmType])
  @@index([orgId])
}

/// План продаж по периодам (команда и менеджеры)
model PlanTarget {
  id         String       @id @default(cuid())
  orgId      String
  period     String // "2026-04" | "2026-Q2" | "2026"
  periodType String // "month" | "quarter" | "year"
  managerId  String? // null = общий план на команду
  target     Float
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  manager    Manager?     @relation(fields: [managerId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, period, periodType, managerId])
  @@index([orgId])
}

model SalesPlan {
  id        String       @id @default(cuid())
  orgId     String
  period    String
  managerId String?
  target    Float
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

/// Пользовательская классификация стадий сделок Bitrix24 для аналитики
model StageConfig {
  id           String   @id @default(cuid())
  orgId        String
  externalId   String
  name         String
  pipelineId   String
  pipelineName String
  crmType      String   @default("bitrix24")
  type         String
  sort         Int      @default(0)
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, externalId, crmType])
  @@index([orgId])
}

// --- Реклама: Meta Ads / TikTok Ads / Google Ads ---

enum AdPlatform {
  META
  TIKTOK
  GOOGLE
}

enum AdConnectionStatus {
  ACTIVE
  EXPIRED
  ERROR
  DISCONNECTED
}

/// Подключение рекламного кабинета. OAuth-токены храним здесь (в проде — через envelope encryption).
model AdConnection {
  id             String             @id @default(cuid())
  orgId          String
  platform       AdPlatform
  accountId      String // ID аккаунта в платформе (act_xxx для Meta, advertiser_id для TikTok, customer_id для Google)
  accountName    String?
  accessToken    String             @db.Text
  refreshToken   String?            @db.Text
  tokenExpiresAt DateTime?
  /// Доп. данные платформы (business_id, manager_customer_id и т.п.)
  extra          String?            @db.Text
  status         AdConnectionStatus @default(ACTIVE)
  lastSyncAt     DateTime?
  lastError      String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  campaigns AdCampaign[]
  insights  AdInsightsDaily[]

  @@unique([orgId, platform, accountId])
  @@index([orgId])
  @@index([status])
}

/// Кампания рекламной платформы (импортируем из API).
model AdCampaign {
  id           String     @id @default(cuid())
  orgId        String
  connectionId String
  platform     AdPlatform
  externalId   String
  name         String
  status       String? // ACTIVE/PAUSED/...
  objective    String?
  dailyBudget  Float?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  connection AdConnection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  insights   AdInsightsDaily[]

  @@unique([connectionId, externalId])
  @@index([orgId])
  @@index([platform])
}

/// Ежедневный снапшот метрик кампании. Обновляется cron-ом раз в час за последние 7 дней.
model AdInsightsDaily {
  id           String     @id @default(cuid())
  orgId        String
  connectionId String
  campaignId   String
  platform     AdPlatform
  date         DateTime   @db.Date
  impressions  Int        @default(0)
  clicks       Int        @default(0)
  spend        Float      @default(0)
  leads        Int        @default(0)
  currency     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  connection AdConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  campaign   AdCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([orgId, date])
  @@index([orgId, platform, date])
}

// --- Attribution: tracking UTM/click-id → deals ---

/// Первичный tracking-touch с лендинга клиента. Создаётся JS-сниппетом при первом визите.
model TrackingTouch {
  id          String   @id @default(cuid())
  orgId       String
  visitorId   String // из cookie (uuid), привязываем к форме при submit
  landingUrl  String?  @db.Text
  referrer    String?  @db.Text
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  fbclid      String?
  ttclid      String?
  gclid       String?
  userAgent   String?  @db.Text
  ip          String?
  createdAt   DateTime @default(now())

  @@index([orgId, visitorId])
  @@index([orgId, createdAt])
  @@index([fbclid])
  @@index([ttclid])
  @@index([gclid])
}

/// Связка CRM-сделки с tracking-touch и рекламной кампанией.
/// Заполняется при получении webhook из CRM (ONCRMDEALADD) + матчинг по fbclid/gclid/email.
model LeadAttribution {
  id          String      @id @default(cuid())
  orgId       String
  /// ID сделки в CRM (Bitrix deal ID, AmoCRM lead ID)
  crmDealId   String
  crmType     String
  /// Откуда пришло — FK на TrackingTouch (если смогли сматчить)
  touchId     String?
  /// К какой кампании привязано (если смогли)
  campaignId  String?
  platform    AdPlatform?
  utmSource   String?
  utmCampaign String?
  clickId     String? // fbclid | ttclid | gclid
  matchedBy   String? // "fbclid" | "email" | "phone" | "utm"
  confidence  Float       @default(1.0) // 0..1
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([orgId, crmDealId, crmType])
  @@index([orgId, campaignId])
  @@index([orgId, platform])
}
